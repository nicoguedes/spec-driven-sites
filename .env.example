# Copy to .env.local in each app (or set in your host's env / secret manager).
# Every value here is OPTIONAL — the site builds and runs with all of them unset.

# Google AdSense publisher id. When unset, the ad wiring is a no-op (no script,
# no <ins> tags). Format: ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# Canonical production origin, used for absolute URLs in metadata/sitemap/hreflang.
# No trailing slash. Defaults to http://localhost:3000 if unset.
NEXT_PUBLIC_SITE_URL=https://example.com

# Optional error monitoring (e.g. Sentry). When unset, monitoring is a no-op.
# NEVER hardcode a DSN in source — it only ever comes from here.
NEXT_PUBLIC_ERROR_DSN=
